---
import Base from "../../../layouts/Base.astro";
---
<Base title="全部文件管理 / myfiles" noindex={true}>
  <main class="pixel-shell grid">
    <section class="pixel-card grid">
      <div><div class="pixel-kicker">admin/files</div><h1>全部文件管理</h1></div>
      <input id="q" class="input" placeholder="搜索文件名 / owner / 文件 ID / SHA256 / MIME" />
      <table class="table"><thead><tr><th>文件</th><th>Owner</th><th>策略</th><th>状态</th><th>操作</th></tr></thead><tbody id="rows"></tbody></table>
    </section>
  </main>
  <script type="module" src="/app/admin-files.js?v=20260513"></script>
</Base>
