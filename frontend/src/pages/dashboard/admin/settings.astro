---
import Base from "../../../layouts/Base.astro";
---

<Base title="站点设置 / myfiles" noindex={true}>
  <main class="pixel-shell settings-admin">
    <section class="pixel-card settings-panel">
      <div class="settings-head">
        <div>
          <div class="pixel-kicker">ADMIN / SETTINGS</div>
          <h1>站点设置</h1>
          <p class="settings-muted">
            使用分板块表单维护 myfiles 运行策略。每个板块单独测试、单独保存。
          </p>
        </div>
        <div class="settings-actions-top">
          <button id="reload" type="button" class="pixel-button secondary">重新读取</button>
        </div>
      </div>

      <div id="alert" role="alert" class="settings-alert" hidden></div>

      <form id="settings-form" class="settings-form">
        <section class="settings-section">
          <div class="section-title">
            <span>01</span>
            <div>
              <h2>站点基础</h2>
              <p>公开品牌、站点 URL 和公开页面策略。</p>
            </div>
          </div>

          <div class="form-grid">
            <label>
              <span>站点名称</span>
              <input name="site.brandName" class="input" autocomplete="off" placeholder="myfiles" />
            </label>

            <label>
              <span>公开域名</span>
              <input name="site.baseUrl" class="input" autocomplete="url" placeholder="https://files.js.gripe" />
            </label>

            <label>
              <span>支持邮箱</span>
              <input name="site.supportEmail" class="input" autocomplete="email" placeholder="helper@js.gripe" />
            </label>

            <label>
              <span>公开文件索引策略</span>
              <select name="seo.publicFilesIndex" class="input">
                <option value="policy">按文件策略决定</option>
                <option value="noindex">全部 noindex</option>
                <option value="index_public_only">仅公开文件允许 index</option>
              </select>
            </label>
          </div>

          <label>
            <span>站点公告</span>
            <textarea name="site.notice" class="input" rows="3" placeholder="可选；为空则不展示"></textarea>
          </label>
        </section>

        <section class="settings-section">
          <div class="section-title">
            <span>02</span>
            <div>
              <h2>上传策略</h2>
              <p>前端只做预校验，真实限制仍以后端为准。</p>
            </div>
          </div>

          <div class="form-grid">
            <label>
              <span>上传上限 MB</span>
              <input name="upload.maxMB" class="input" type="number" min="1" step="1" placeholder="100" />
            </label>

            <label>
              <span>允许匿名上传</span>
              <select name="upload.allowAnonymous" class="input">
                <option value="true">允许</option>
                <option value="false">不允许，仅登录用户</option>
              </select>
            </label>

            <label>
              <span>MIME 策略</span>
              <select name="upload.mimeMode" class="input">
                <option value="all">允许全部 */*</option>
                <option value="images">仅图片</option>
                <option value="custom">自定义列表</option>
              </select>
            </label>

            <label>
              <span>批次最大文件数</span>
              <input name="upload.maxFilesPerBatch" class="input" type="number" min="1" step="1" placeholder="20" />
            </label>
          </div>

          <label>
            <span>自定义 MIME 列表</span>
            <textarea name="upload.allowedMimeTypes" class="input" rows="3" placeholder="每行一个，例如 image/png&#10;application/pdf"></textarea>
          </label>
        </section>

        <section class="settings-section">
          <div class="section-title">
            <span>03</span>
            <div>
              <h2>默认文件策略</h2>
              <p>新上传文件的默认访问策略，管理员仍可对单文件单独修改。</p>
            </div>
          </div>

          <div class="form-grid">
            <label>
              <span>默认公开</span>
              <select name="file.defaultPublic" class="input">
                <option value="true">公开访问</option>
                <option value="false">仅本人/授权访问</option>
              </select>
            </label>

            <label>
              <span>访问前确认</span>
              <select name="file.defaultRequireConfirm" class="input">
                <option value="false">不需要确认</option>
                <option value="true">需要确认</option>
              </select>
            </label>

            <label>
              <span>地区策略</span>
              <select name="file.defaultRegionPolicy" class="input">
                <option value="global">全球允许</option>
                <option value="cn_only">仅中国大陆</option>
                <option value="non_cn_only">仅非中国大陆</option>
                <option value="deny_all">全部拒绝，管理员手动放行</option>
              </select>
            </label>

            <label>
              <span>热链策略</span>
              <select name="file.defaultHotlinkPolicy" class="input">
                <option value="allow">允许热链</option>
                <option value="same_site">仅同站</option>
                <option value="deny">禁止热链</option>
              </select>
            </label>
          </div>
        </section>

        <section class="settings-section">
          <div class="section-title">
            <span>04</span>
            <div>
              <h2>存储通道</h2>
              <p>用于对接 gateway.js.gripe/api/v1/tgbots 或本地存储通道。</p>
            </div>
          </div>

          <div class="form-grid">
            <label>
              <span>存储模式</span>
              <select name="storage.mode" class="input">
                <option value="tgbots">tgbots</option>
                <option value="local">local</option>
                <option value="disabled">disabled</option>
              </select>
            </label>

            <label>
              <span>上传接口</span>
              <input name="storage.uploadUrl" class="input" autocomplete="off" placeholder="https://gateway.js.gripe/api/v1/tgbots" />
            </label>

            <label>
              <span>Telegram Chat ID</span>
              <input name="storage.chatId" class="input" autocomplete="off" placeholder="-5245394953" />
            </label>

            <label>
              <span>超时秒数</span>
              <input name="storage.timeoutSeconds" class="input" type="number" min="5" step="1" placeholder="120" />
            </label>

            <label>
              <span>本地目录</span>
              <input name="storage.localDir" class="input" autocomplete="off" placeholder="/var/lib/myfiles/storage" />
            </label>
          </div>

          <label>
              <span>存储 API Key</span>
            <input name="storage.apiKey" class="input" type="password" autocomplete="off" autocapitalize="off" spellcheck="false" data-lpignore="true" data-1p-ignore="true" placeholder="留空则不覆盖已有值" />
          </label>

          <p class="settings-hint">
            API Key 只在保存时写入，页面不会回显。首次启用 tgbots 时必须填写；Telegram 通道保存前会先发送测试文件到目标 Chat ID，测试失败不会启用。
          </p>
        </section>

        <section class="settings-section">
          <div class="section-title">
            <span>05</span>
            <div>
              <h2>CDN / 缓存</h2>
              <p>用于后续文件公开页和静态资源缓存策略。</p>
            </div>
          </div>

          <div class="form-grid">
            <label>
              <span>启用 CDN 标记</span>
              <select name="cdn.enabled" class="input">
                <option value="true">启用</option>
                <option value="false">关闭</option>
              </select>
            </label>

            <label>
              <span>CDN Base URL</span>
              <input name="cdn.baseUrl" class="input" autocomplete="url" placeholder="https://files.js.gripe" />
            </label>

            <label>
              <span>公开文件 Cache-Control</span>
              <input name="cdn.publicCacheControl" class="input" autocomplete="off" placeholder="public, max-age=31536000, immutable" />
            </label>

            <label>
              <span>私有页面 Cache-Control</span>
              <input name="cdn.privateCacheControl" class="input" autocomplete="off" placeholder="no-store" />
            </label>
          </div>
        </section>

        <section class="settings-section">
          <div class="section-title">
            <span>06</span>
            <div>
              <h2>安全与会话</h2>
              <p>控制 myfiles 自有会话和后台安全策略。</p>
            </div>
          </div>

          <div class="form-grid">
            <label>
              <span>Session Cookie 名称</span>
              <input name="security.sessionCookieName" class="input" autocomplete="off" placeholder="myfiles_session" />
            </label>

            <label>
              <span>Session 有效期小时</span>
              <input name="security.sessionTtlHours" class="input" type="number" min="1" step="1" placeholder="168" />
            </label>

            <label>
              <span>Cookie Secure</span>
              <select name="security.cookieSecure" class="input">
                <option value="true">true</option>
                <option value="false">false</option>
              </select>
            </label>

            <label>
              <span>后台审计保留天数</span>
              <input name="audit.retentionDays" class="input" type="number" min="1" step="1" placeholder="180" />
            </label>
          </div>
        </section>

      </form>
    </section>
  </main>

  <style>
    .settings-admin .settings-panel {
      max-width: 1180px;
      margin: 32px auto;
    }

    .settings-head {
      display: flex;
      gap: 24px;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 24px;
    }

    .settings-muted,
    .settings-hint,
    .section-title p {
      color: var(--muted);
    }

    .settings-actions-top {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .pixel-button.secondary {
      background: transparent;
      color: var(--text);
    }

    .settings-form {
      display: grid;
      gap: 22px;
    }

    .settings-section {
      border: 2px solid var(--border);
      border-radius: 18px;
      padding: 20px;
      background: rgba(255, 255, 255, 0.03);
    }

    .section-title {
      display: flex;
      gap: 14px;
      align-items: flex-start;
      margin-bottom: 16px;
    }

    .section-title > span {
      display: inline-flex;
      width: 42px;
      height: 42px;
      align-items: center;
      justify-content: center;
      border: 2px solid var(--accent);
      border-radius: 12px;
      color: var(--accent);
      font-weight: 800;
      letter-spacing: 0.08em;
    }

    .section-title h2 {
      margin: 0 0 6px;
      font-size: 20px;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }

    .settings-form label {
      display: grid;
      gap: 8px;
      color: var(--muted);
    }

    .settings-form label > span {
      color: var(--text);
      font-weight: 700;
    }

    .settings-form select.input,
    .settings-form input.input,
    .settings-form textarea.input {
      width: 100%;
      box-sizing: border-box;
    }

    .settings-alert {
      border: 2px solid var(--accent);
      border-radius: 14px;
      padding: 12px 14px;
      margin-bottom: 18px;
      color: var(--accent);
    }

    .settings-alert.ok,
    .section-alert.ok {
      color: #7dffb2;
      border-color: #7dffb2;
    }

    .section-alert {
      border: 2px solid var(--danger);
      border-radius: 8px;
      padding: 12px 14px;
      margin-top: 16px;
      color: var(--danger);
      background: rgba(255, 92, 119, 0.08);
      overflow-wrap: anywhere;
    }

    @media (max-width: 780px) {
      .settings-head,
      .form-grid {
        grid-template-columns: 1fr;
        display: grid;
      }

      .settings-actions-top {
        width: 100%;
      }
    }
  </style>

  <script type="module" src="/app/settings.js?v=20260513"></script>
</Base>
