---
import Base from "../../layouts/Base.astro";
---
<Base title="我的文件 / myfiles" noindex={true}>
  <main class="pixel-shell grid">
    <section class="pixel-card grid">
      <div class="brand"><img src="/assets/mascot-files.png" alt="" /><div><div class="pixel-kicker">files</div><h1>我的文件</h1></div></div>
      <input id="q" class="input" placeholder="搜索文件名 / 文件 ID / SHA256 / MIME" />
      <div id="alert" role="alert"></div>
      <table class="table"><thead><tr><th>文件</th><th>MIME</th><th>大小</th><th>时间</th><th>操作</th></tr></thead><tbody id="rows"></tbody></table>
    </section>
  </main>
  <script type="module" src="/app/files.js?v=20260513"></script>
</Base>
