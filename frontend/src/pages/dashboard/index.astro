---
import Base from "../../layouts/Base.astro";
---
<Base titleKey="dashboard" noindex={true}>
  <main id="main-content" class="console-shell">
    <aside class="console-sidebar">
      <a class="console-brand" href="/dashboard">
        <span class="console-brand-mark" aria-hidden="true">MF</span>
        <span data-brand>myfiles</span>
      </a>
      <nav id="nav" class="console-nav"></nav>
    </aside>
    <section class="console-main">
      <header class="console-topbar">
        <div>
          <div class="pixel-kicker" data-i18n="dashboardKicker">控制台</div>
          <h1 data-i18n="dashboardTitle">文件控制台</h1>
        </div>
        <div class="console-user">
          <p id="profile" class="muted"></p>
          <a class="pixel-button secondary compact" href="/" data-i18n="home">首页</a>
        </div>
      </header>
      <div id="dashboard-app" class="console-workspace">
        <div class="console-loading">Loading...</div>
      </div>
    </section>
  </main>
  <script type="module" src="/app/dashboard.js?v=20260619settings3"></script>
</Base>
