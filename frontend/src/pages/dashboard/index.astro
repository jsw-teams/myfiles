---
import Base from "../../layouts/Base.astro";
---
<Base titleKey="dashboard" noindex={true}>
  <main id="main-content" class="pixel-shell dashboard-layout unified-dashboard">
    <aside class="pixel-card sidebar">
      <div class="brand"><img src="/assets/mascot-files.png" alt="" /><strong data-brand>myfiles</strong></div>
      <nav id="nav" class="nav"></nav>
    </aside>
    <section id="dashboard-app" class="grid">
      <div class="dashboard-hero">
        <img src="/assets/mascot-files.png" alt="" />
        <div>
          <div class="pixel-kicker" data-i18n="dashboardKicker">控制台</div>
          <h1 id="title" data-i18n="dashboardTitle">文件控制台</h1>
          <p id="profile" class="muted"></p>
        </div>
      </div>
      <div id="cards" class="grid two"></div>
    </section>
  </main>
  <script type="module" src="/app/dashboard.js?v=20260516m"></script>
</Base>
