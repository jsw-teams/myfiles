---
import Base from "../layouts/Base.astro";
---
<Base titleKey="home">
  <main id="main-content" class="pixel-shell home-shell">
    <section class="home-panel">
      <div class="home-art" aria-hidden="true">
        <img src="/assets/pickup-hero-pixel-bear.png" alt="" />
      </div>

      <div class="home-content grid">
        <div class="brand">
          <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <path d="M12 3v12"></path>
              <path d="m17 8-5-5-5 5"></path>
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            </svg>
          </span>
          <div>
            <h1 data-brand>myfiles</h1>
          </div>
        </div>

        <div class="home-actions" aria-live="polite">
          <a id="account-login" class="pixel-button secondary compact" href="/login" data-i18n="accountLogin">统一账户登录</a>
          <a id="account-dashboard" class="pixel-button compact" href="/dashboard" hidden data-i18n="dashboardButton">进入控制台</a>
        </div>

        <section class="action-panel pickup-panel">
          <div>
            <div class="panel-title"><span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" role="img">
                <path d="M2.6 17.4A2 2 0 0 0 2 18.8V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h1a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h.2a2 2 0 0 0 1.4-.6l.8-.8a6.5 6.5 0 1 0-4-4z"></path>
                <circle cx="16.5" cy="7.5" r=".5" fill="currentColor"></circle>
              </svg>
            </span><span data-i18n="pickupTitle">取件码</span></div>
            <p class="muted" data-i18n="pickupDesc">输入对方给你的 24 小时取件码，直接打开本次上传的文件。</p>
          </div>
          <form id="pickup-form" class="pickup-form">
            <input id="pickup-code" class="input pickup-input" name="code" inputmode="latin" autocomplete="one-time-code" placeholder="例如 8F7K2QMA" data-i18n-placeholder="pickupPlaceholder" maxlength="12" />
            <button class="pixel-button compact" type="submit" data-i18n="pickupButton">取件</button>
          </form>
          <div id="pickup-status" role="alert"></div>
        </section>

        <form id="upload-form" class="action-panel grid" enctype="multipart/form-data">
          <div class="panel-title"><span class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <path d="M12 3v12"></path>
              <path d="m17 8-5-5-5 5"></path>
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            </svg>
          </span><span data-i18n="uploadTitle">上传文件</span></div>
          <label class="upload-zone">
            <strong data-i18n="uploadChoose">选择或拖放文件</strong>
            <p id="upload-desc" class="muted" data-i18n="uploadDesc">上传完成后会生成 24 小时取件码，可发给对方快捷获取。</p>
            <input id="file-input" name="files" type="file" multiple hidden />
          </label>
          <div id="selected" class="file-list"></div>
          <button class="pixel-button" type="submit" data-i18n="uploadButton">上传文件</button>
        </form>

        <div id="status" role="alert"></div>
        <section id="result-panel" class="action-panel grid" hidden>
          <div class="panel-title"><span class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="m9 12 2 2 4-4"></path>
            </svg>
          </span><span data-i18n="resultTitle">取件结果</span></div>
          <div id="result" class="grid"></div>
        </section>
      </div>
    </section>
    <div id="upload-modal" class="upload-modal" hidden>
      <div class="upload-dialog" role="dialog" aria-modal="true" aria-labelledby="upload-dialog-title">
        <div class="mascot-chat">
          <img src="/assets/mascot-files.png" alt="" />
          <div>
            <strong id="upload-dialog-title" data-i18n="movingFiles">黑熊正在搬运文件</strong>
            <span id="upload-progress-text" data-i18n="waitingUpload">等待上传</span>
          </div>
        </div>
        <div class="progress-bar"><span id="upload-progress-bar"></span></div>
        <button id="cancel-upload" class="pixel-button danger compact" type="button" data-i18n="cancelUpload">取消上传</button>
      </div>
    </div>
  </main>
  <script type="module" src="/app/upload-result.js?v=20260529a"></script>
  <script>
    const form = document.querySelector("#upload-form");
    const input = document.querySelector("#file-input");
    const selected = document.querySelector("#selected");
    const status = document.querySelector("#status");
    const progressBar = document.querySelector("#upload-progress-bar");
    const progressText = document.querySelector("#upload-progress-text");
    const uploadModal = document.querySelector("#upload-modal");
    const cancelUpload = document.querySelector("#cancel-upload");
    const pickupForm = document.querySelector("#pickup-form");
    const pickupInput = document.querySelector("#pickup-code");
    const pickupStatus = document.querySelector("#pickup-status");
    const accountLogin = document.querySelector("#account-login");
    const accountDashboard = document.querySelector("#account-dashboard");
    const uploadDesc = document.querySelector("#upload-desc");
    let labels = window.siteI18n?.labels || { fileBadge: "文件" };
    let bootstrap = null;
    let account = null;
    let currentUpload = null;
    let selectedFiles = [];
    fetch("/api/bootstrap").then(r => r.json()).then(j => { bootstrap = j; }).catch(() => {});
    detectAccount();
    document.addEventListener("site-i18n-ready", (event) => { labels = event.detail?.labels || labels; renderAccountState(); });

    cancelUpload.addEventListener("click", () => {
      currentUpload?.abort();
      setProgress(0, msg("uploadCancelled"));
      uploadModal.hidden = true;
      status.className = "pixel-alert";
      status.textContent = msg("uploadCancelled");
    });

    pickupInput.addEventListener("input", () => {
      pickupInput.value = normalizePickupCode(pickupInput.value);
    });

    pickupForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      const code = normalizePickupCode(pickupInput.value);
      pickupStatus.className = "";
      pickupStatus.textContent = "";
      if (!code) {
        pickupStatus.className = "pixel-alert";
        pickupStatus.textContent = msg("pickupRequired");
        return;
      }
      pickupStatus.className = "pixel-alert ok";
      pickupStatus.textContent = msg("pickupChecking");
      try {
        const res = await fetch("/api/pickup/" + encodeURIComponent(code), { cache: "no-store" });
        const json = await res.json().catch(() => ({}));
        if (!res.ok || !json.ok) {
          pickupStatus.className = "pixel-alert";
          pickupStatus.textContent = msg("pickupMissing");
          return;
        }
        location.href = "/?code=" + encodeURIComponent(code);
      } catch {
        pickupStatus.className = "pixel-alert";
        pickupStatus.textContent = msg("networkError");
      }
    });

    input.addEventListener("change", () => {
      selectedFiles = Array.from(input.files || []);
      syncFileInput();
      renderSelectedFiles();
    });

    selected.addEventListener("click", (event) => {
      const remove = event.target.closest("[data-remove-file]");
      if (!remove) return;
      selectedFiles.splice(Number(remove.dataset.removeFile), 1);
      syncFileInput();
      renderSelectedFiles();
    });

    function renderSelectedFiles() {
      selected.innerHTML = "";
      selectedFiles.forEach((file, index) => {
        const row = document.createElement("div");
        row.className = "file-row";
        const isImage = file.type.startsWith("image/");
        const preview = isImage ? `<img class="file-preview" alt="" />` : `<span class="file-badge" aria-hidden="true">${fileIcon(file)}</span>`;
        row.innerHTML = `${preview}<div class="file-info"><strong>${escapeHtml(file.name)}</strong><span>${escapeHtml(file.type || fileKind(file))} · ${formatSize(file.size)}</span></div><button class="icon-button danger" type="button" data-remove-file="${index}" aria-label="Remove ${escapeAttr(file.name)}">×</button>`;
        if (isImage) row.querySelector("img").src = URL.createObjectURL(file);
        selected.appendChild(row);
      });
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      status.className = "";
      status.textContent = "";
      if (!selectedFiles.length) {
        status.className = "pixel-alert";
        status.textContent = msg("chooseFile");
        return;
      }
      const max = bootstrap?.upload?.maxBytes;
      if (max) {
        for (const f of selectedFiles) {
          if (f.size > max) {
            status.className = "pixel-alert";
            status.textContent = msg("uploadTooLarge");
            return;
          }
        }
      }
      status.className = "";
      status.textContent = "";
      uploadModal.hidden = false;
      setUploadProgress(0, totalSelectedBytes(), 0, msg("uploadPrepare"));
      let json = {};
      try {
        json = await uploadWithProgress(selectedFiles);
      } catch (err) {
        uploadModal.hidden = true;
        status.className = "pixel-alert";
        status.textContent = err?.name === "AbortError" ? msg("uploadCancelled") : msg("networkError");
        return;
      }
      if (!json.ok || json.status === "failed") {
        uploadModal.hidden = true;
        status.className = "pixel-alert";
        status.textContent = uploadErrorMessage(json.code, firstItemError(json));
        setProgress(100, msg("uploadFailed"));
        return;
      }
      setProgress(100, msg("uploadDone"));
      location.href = json.resultPath || json.downloadPath;
    });

    async function detectAccount() {
      try {
        const res = await fetch("/api/account/me", { cache: "no-store" });
        const json = await res.json().catch(() => ({}));
        account = res.ok && json.ok ? json : null;
      } catch {
        account = null;
      }
      renderAccountState();
    }

    function renderAccountState() {
      const signedIn = Boolean(account?.user?.id);
      uploadDesc.textContent = signedIn ? msg("uploadDescSignedIn") : msg("uploadDesc");
      accountLogin.hidden = signedIn;
      accountDashboard.hidden = !signedIn;
      document.documentElement.dataset.accountState = signedIn ? "signed-in" : "guest";
    }

    async function uploadWithProgress(files) {
      const controller = new AbortController();
      const sessionKey = uploadSessionKey(files);
      const savedSession = readUploadSession(sessionKey);
      const activeUpload = {
        controller,
        uploadId: "",
        sessionKey,
        abort() {
          controller.abort();
          if (this.uploadId) cancelChunkUpload(this.uploadId);
          localStorage.removeItem(this.sessionKey);
        }
      };
      currentUpload = activeUpload;
      const total = files.reduce((sum, file) => sum + file.size, 0);
      let completedUploaded = 0;
      const activeChunkBytes = new Map();
      const startedAt = performance.now();
      const uploadPlan = preferredUploadPlan(total);

      try {
        const init = await fetchJSON("/api/upload/chunk/init", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            uploadId: savedSession?.uploadId || "",
            chunkSize: savedSession?.chunkSize || uploadPlan.chunkSize,
            files: files.map((file) => ({ name: file.name, size: file.size, type: file.type || "" }))
          }),
          signal: controller.signal
        });
        if (!init.ok) return init;
        const uploadId = init.uploadId;
        const chunkSize = Number(init.chunkSize || 4 * 1024 * 1024);
        const received = init.received || {};
        activeUpload.uploadId = uploadId;
        localStorage.setItem(sessionKey, JSON.stringify({ uploadId, chunkSize, expiresAt: init.expiresAt || "", files: uploadSessionFiles(files) }));
        completedUploaded = uploadedBytesFromReceived(files, received, chunkSize);
        if (completedUploaded > 0) {
          setUploadProgress(completedUploaded, total, speedSince(completedUploaded, startedAt), msg("uploadResuming"));
        }

        const tasks = [];
        for (let fileIndex = 0; fileIndex < files.length; fileIndex++) {
          const file = files[fileIndex];
          const chunks = Math.max(1, Math.ceil(file.size / chunkSize));
          for (let chunkIndex = 0; chunkIndex < chunks; chunkIndex++) {
            if (received[String(fileIndex)]?.[chunkIndex]) continue;
            const start = chunkIndex * chunkSize;
            const end = Math.min(file.size, start + chunkSize);
            tasks.push({ file, fileIndex, chunkIndex, chunks, start, end, size: end - start });
          }
        }
        let cursor = 0;
        let failed = null;
        const concurrency = Math.min(uploadPlan.concurrency, Math.max(1, tasks.length));
        const updateProgress = (label) => {
          let inFlight = 0;
          activeChunkBytes.forEach((value) => { inFlight += value; });
          const uploaded = Math.min(total, completedUploaded + inFlight);
          setUploadProgress(uploaded, total, speedSince(uploaded, startedAt), label);
        };
        const workers = Array.from({ length: concurrency }, async () => {
          while (!failed && cursor < tasks.length) {
            const task = tasks[cursor++];
            const key = `${task.fileIndex}:${task.chunkIndex}`;
            const label = msg("uploadingFile").replace("{name}", task.file.name);
            try {
              const chunkStartedAt = performance.now();
              await uploadChunkWithRetry(uploadId, task.fileIndex, task.chunkIndex, task.file.slice(task.start, task.end), controller.signal, (loaded) => {
                activeChunkBytes.set(key, Math.min(loaded, task.size));
                updateProgress(label);
              });
              rememberUploadSample(task.size, performance.now() - chunkStartedAt, null);
              activeChunkBytes.delete(key);
              completedUploaded += task.size;
              if (!received[String(task.fileIndex)]) received[String(task.fileIndex)] = Array(task.chunks).fill(false);
              received[String(task.fileIndex)][task.chunkIndex] = true;
              updateProgress(label);
            } catch (err) {
              activeChunkBytes.delete(key);
              rememberUploadSample(task.size, 0, err);
              if (isRetryableUploadError(err)) rememberWeakUploadNetwork();
              if (err?.name === "AbortError") throw err;
              failed = err;
              controller.abort();
            }
          }
        });
        try {
          await Promise.all(workers);
        } catch (err) {
          if (!failed || err?.name !== "AbortError") throw err;
        }
        if (failed) {
          if (["upload_expired", "upload_not_found"].includes(failed.code)) localStorage.removeItem(sessionKey);
          return { ok: false, code: failed.code, error: failed.message || msg("uploadFailedGeneric") };
        }

        setUploadProgress(total, total, speedSince(total, startedAt), msg("uploadFinalizing"));
        const result = await fetchJSON("/api/upload/chunk/complete", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ uploadId }),
          signal: controller.signal
        });
        if (result.ok) {
          localStorage.removeItem(sessionKey);
          activeUpload.uploadId = "";
        }
        return result;
      } finally {
        if (currentUpload === activeUpload) currentUpload = null;
      }
    }

    function setProgress(percent, text) {
      progressBar.style.width = `${Math.max(0, Math.min(100, percent))}%`;
      progressText.textContent = text;
    }

    function setUploadProgress(uploaded, total, speed, label) {
      const pct = total > 0 ? Math.round((uploaded / total) * 100) : 0;
      setProgress(pct, `${label} · ${msg("uploadStats")
        .replace("{total}", formatSize(total))
        .replace("{uploaded}", formatSize(uploaded))
        .replace("{speed}", formatRate(speed))
        .replace("{pct}", pct)}`);
    }

    async function fetchJSON(url, options) {
      const res = await fetch(url, options);
      const body = await res.json().catch(() => ({}));
      if (!res.ok || body.ok === false) {
        return { ok: false, code: body.code, error: body.error || msg("uploadFailedGeneric") };
      }
      return body;
    }

    async function uploadChunkWithRetry(uploadId, fileIndex, chunkIndex, chunk, signal, onProgress) {
      let lastErr = null;
      for (let attempt = 0; attempt < 4; attempt++) {
        if (signal?.aborted) throw new DOMException(msg("uploadCancelled"), "AbortError");
        try {
          return await uploadChunk(uploadId, fileIndex, chunkIndex, chunk, signal, onProgress);
        } catch (err) {
          if (err?.name === "AbortError") throw err;
          lastErr = err;
          if (!isRetryableUploadError(err) || attempt === 3) break;
          onProgress(0);
          await sleep(800 * (attempt + 1), signal);
        }
      }
      throw lastErr || new Error(msg("uploadFailedGeneric"));
    }

    function isRetryableUploadError(err) {
      const status = Number(err?.status || 0);
      return err?.code === "upload_timeout" || err?.code === "network_error" || [408, 429, 500, 502, 503, 504, 520, 522, 524].includes(status);
    }

    function preferredUploadPlan(totalBytes) {
      const fastUntil = Number(localStorage.getItem("myfiles:fast-upload-until") || 0);
      const connection = navigator.connection || navigator.webkitConnection || navigator.mozConnection;
      const effectiveType = String(connection?.effectiveType || "");
      const downlink = Number(connection?.downlink || 0);
      if (connection?.saveData || /^(slow-2g|2g|3g)$/i.test(effectiveType)) {
        return { chunkSize: 2 * 1024 * 1024, concurrency: 2 };
      }
      if (fastUntil > Date.now() || /^(4g)$/i.test(effectiveType) || downlink >= 8) {
        return {
          chunkSize: totalBytes >= 64 * 1024 * 1024 ? 16 * 1024 * 1024 : 8 * 1024 * 1024,
          concurrency: 4
        };
      }
      if (totalBytes >= 64 * 1024 * 1024) return { chunkSize: 12 * 1024 * 1024, concurrency: 4 };
      if (totalBytes >= 16 * 1024 * 1024) return { chunkSize: 8 * 1024 * 1024, concurrency: 4 };
      return { chunkSize: 4 * 1024 * 1024, concurrency: 3 };
    }

    function rememberWeakUploadNetwork() {
      localStorage.removeItem("myfiles:fast-upload-until");
    }

    function rememberFastUploadNetwork() {
      localStorage.setItem("myfiles:fast-upload-until", String(Date.now() + 6 * 60 * 60 * 1000));
      localStorage.removeItem("myfiles:weak-upload-until");
    }

    function rememberUploadSample(bytes, elapsedMs, err) {
      if (err) return;
      const seconds = elapsedMs / 1000;
      if (seconds <= 0 || bytes < 128 * 1024) return;
      const rate = bytes / seconds;
      if (rate >= 1024 * 1024) {
        rememberFastUploadNetwork();
      } else if (bytes >= 2 * 1024 * 1024 && rate < 96 * 1024) {
        rememberWeakUploadNetwork();
      }
    }

    function sleep(ms, signal) {
      return new Promise((resolve, reject) => {
        const timer = setTimeout(resolve, ms);
        signal?.addEventListener("abort", () => {
          clearTimeout(timer);
          reject(new DOMException(msg("uploadCancelled"), "AbortError"));
        }, { once: true });
      });
    }

    function uploadChunk(uploadId, fileIndex, chunkIndex, chunk, signal, onProgress) {
      return new Promise((resolve, reject) => {
        const xhr = new XMLHttpRequest();
        xhr.open("POST", `/api/upload/chunk/${encodeURIComponent(uploadId)}/file/${fileIndex}?chunk=${chunkIndex}`);
        xhr.responseType = "json";
        xhr.timeout = 95000;
        const cleanup = () => signal?.removeEventListener("abort", abort);
        const abort = () => {
          cleanup();
          xhr.abort();
          reject(new DOMException(msg("uploadCancelled"), "AbortError"));
        };
        signal?.addEventListener("abort", abort, { once: true });
        xhr.upload.onprogress = (event) => {
          if (event.lengthComputable) onProgress(event.loaded);
        };
        xhr.onload = () => {
          cleanup();
          const body = xhr.response || {};
          if (xhr.status < 200 || xhr.status >= 300 || body.ok === false) {
            const err = new Error(body.error || msg("uploadFailedGeneric"));
            err.code = body.code || "upload_failed";
            err.status = xhr.status;
            reject(err);
            return;
          }
          resolve(body);
        };
        xhr.onerror = () => {
          cleanup();
          const err = new Error(msg("networkError"));
          err.code = "network_error";
          reject(err);
        };
        xhr.ontimeout = () => {
          cleanup();
          const err = new Error(msg("networkError"));
          err.code = "upload_timeout";
          err.status = 408;
          reject(err);
        };
        xhr.onabort = () => {
          cleanup();
          reject(new DOMException(msg("uploadCancelled"), "AbortError"));
        };
        xhr.send(chunk);
      });
    }

    function cancelChunkUpload(uploadId) {
      fetch("/api/upload/chunk/cancel", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ uploadId }),
        keepalive: true
      }).catch(() => {});
    }

    function uploadSessionKey(files) {
      const payload = uploadSessionFiles(files).map((file) => `${file.name}:${file.size}:${file.type}:${file.lastModified}`).join("|");
      return `myfiles:chunk-upload:${payload}`;
    }

    function uploadSessionFiles(files) {
      return files.map((file) => ({
        name: file.name,
        size: file.size,
        type: file.type || "",
        lastModified: file.lastModified || 0
      }));
    }

    function readUploadSession(key) {
      try {
        const value = JSON.parse(localStorage.getItem(key) || "null");
        if (!value?.uploadId) return null;
        if (value.expiresAt && Date.parse(value.expiresAt) <= Date.now()) {
          localStorage.removeItem(key);
          return null;
        }
        return value;
      } catch {
        localStorage.removeItem(key);
        return null;
      }
    }

    function uploadedBytesFromReceived(files, received, chunkSize) {
      let total = 0;
      files.forEach((file, fileIndex) => {
        const chunks = received[String(fileIndex)] || [];
        chunks.forEach((ok, chunkIndex) => {
          if (!ok) return;
          const start = chunkIndex * chunkSize;
          total += Math.max(0, Math.min(file.size, start + chunkSize) - start);
        });
      });
      return total;
    }

    function totalSelectedBytes() {
      return selectedFiles.reduce((sum, file) => sum + file.size, 0);
    }

    function speedSince(uploaded, startedAt) {
      const seconds = Math.max(0.2, (performance.now() - startedAt) / 1000);
      return uploaded / seconds;
    }

    function firstItemError(json) {
      const item = Array.isArray(json.items) ? json.items.find((entry) => entry && entry.ok === false) : null;
      return item?.error || json.error;
    }

    function uploadErrorMessage(code, fallback) {
      const messages = {
        unauthorized: msg("authNeeded"),
        upload_too_large: msg("uploadTooLarge"),
        file_required: msg("fileRequired"),
        mime_not_allowed: msg("mimeNotAllowed"),
        storage_upload_failed: msg("storageFailed"),
        db_error: msg("dbFailed"),
        upload_cancelled: msg("uploadCancelled"),
        upload_expired: msg("uploadExpired"),
        upload_not_found: msg("uploadExpired"),
        upload_incomplete: msg("uploadIncomplete")
      };
      return messages[code] || fallback || msg("uploadFailedGeneric");
    }

    function msg(key) {
      return labels[key] || key;
    }

    function syncFileInput() {
      const dt = new DataTransfer();
      selectedFiles.forEach((file) => dt.items.add(file));
      input.files = dt.files;
    }

    function fileIcon(file) {
      const type = file.type || "";
      const name = file.name || "";
      if (type.startsWith("image/")) return iconSvg("image");
      if (type.startsWith("video/")) return iconSvg("video");
      if (type.startsWith("audio/")) return iconSvg("audio");
      if (/pdf$/i.test(type) || /\.pdf$/i.test(name)) return iconSvg("fileText");
      if (/zip|rar|7z|tar|gzip|compressed|archive/i.test(type) || /\.(zip|rar|7z|tar|gz)$/i.test(name)) return iconSvg("archive");
      if (/json|javascript|typescript|xml|html|css|shell|python|go|rust|code/i.test(type) || /\.(js|ts|json|xml|html|css|sh|py|go|rs)$/i.test(name)) return iconSvg("code");
      if (/spreadsheet|excel|csv/i.test(type) || /\.(xlsx?|csv)$/i.test(name)) return iconSvg("table");
      if (/presentation|powerpoint/i.test(type) || /\.(pptx?|key)$/i.test(name)) return iconSvg("presentation");
      if (/text|document|word/i.test(type) || /\.(txt|md|docx?|rtf)$/i.test(name)) return iconSvg("fileText");
      return iconSvg("file");
    }

    function iconSvg(name) {
      const paths = {
        image: '<rect width="18" height="18" x="3" y="3" rx="2"></rect><circle cx="9" cy="9" r="2"></circle><path d="m21 15-3.1-3.1a2 2 0 0 0-2.8 0L6 21"></path>',
        video: '<path d="m16 13 5 3V8l-5 3"></path><rect x="3" y="5" width="13" height="14" rx="2"></rect>',
