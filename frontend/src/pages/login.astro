---
import Base from "../layouts/Base.astro";
---
<Base titleKey="login" noindex={true}>
  <main id="main-content" class="login-page pixel-auth">
    <section class="login-card">
      <div class="login-art">
        <img src="/assets/mascot-files.png" alt="" />
        <div class="bear-bubble">
          <div class="pixel-kicker" data-i18n="loginKicker">身份验证</div>
          <h1 data-brand>myfiles</h1>
          <p data-i18n="loginBubble">黑熊会把账户授权安全带回文件服务。</p>
        </div>
      </div>
      <div class="login-form-panel">
        <h2 data-i18n="loginTitle">登录</h2>
        <p class="muted" data-i18n="loginDesc">登录成功后将进入文件控制台，可管理文件、建立分享取件码和查看策略。</p>
        <button id="login" class="pixel-button" data-i18n="loginButton">打开登录</button>
        <div id="alert" class="pixel-alert" role="alert" style="display:none"></div>
      </div>
    </section>
  </main>
  <script>
    const btn = document.querySelector("#login");
    const alertBox = document.querySelector("#alert");
    let labels = { loginError: "登录未完成，请重试。", loginRetry: "登录未完成，请重新尝试。" };
    document.addEventListener("site-i18n-ready", (event) => { labels = event.detail?.labels || labels; });
    const showError = (text) => { alertBox.textContent = text || labels.loginError; alertBox.style.display = "block"; };
    const params = new URLSearchParams(location.search);
    if (params.get("error")) showError(labels.loginRetry);

    btn.addEventListener("click", () => {
      alertBox.style.display = "none";
      const popup = window.open("/auth/account/start?popup=1", "myfilesAccountLogin", "popup=yes,width=520,height=720");
      if (!popup) {
        location.href = "/auth/account/start?popup=1";
        return;
      }
      const timer = setInterval(() => {
        if (popup.closed) {
          clearInterval(timer);
        }
      }, 700);
    });

    window.addEventListener("message", (event) => {
      if (event.origin !== location.origin) return;
      const data = event.data || {};
      if (data.source !== "myfiles-auth") return;
      if (data.status === "ok") location.href = data.redirectTo || "/dashboard";
      else showError(data.message);
    });
  </script>
</Base>
