---
import "../styles/pixel.css";
const { titleKey = "home", noindex = false } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>myfiles</title>
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <meta name="description" content="安全上传文件，并通过 24 小时取件码进行临时分享。" />
    <meta name="application-name" content="myfiles" />
    <meta name="geo.region" content="001" data-geo-region />
    <meta property="og:site_name" content="myfiles" />
    <meta property="og:title" content="myfiles" />
    <meta property="og:description" content="上传文件并通过 24 小时取件码进行临时分享。" />
    <meta property="og:type" content="website" />
    <link rel="canonical" href="/" />
    <link rel="shortcut icon" type="image/png" href="/assets/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/site-icon-512.png" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
  </head>
  <body data-title-key={titleKey}>
    <a class="skip-link" href="#main-content" data-i18n="skipContent">跳到主内容</a>
    <slot />
    <script type="module" src="/app/shell-nav.js?v=20260616accounts3"></script>
    <script type="module" src="/app/site-i18n.js?v=20260616accounts3"></script>
    <script>
      (() => {
        const lang = (navigator.language || "zh-CN").toLowerCase().startsWith("zh") ? "zh-CN" : "en";
        document.documentElement.lang = lang;
        const dict = {
          "zh-CN": { skipContent: "跳到主内容" },
          en: { skipContent: "Skip to content" }
        };
        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const value = dict[lang][node.dataset.i18n];
          if (value) node.textContent = value;
        });
      })();
    </script>
    <script src="/assets/agent-discovery.js?v=20260616accounts3" defer></script>
  </body>
</html>
